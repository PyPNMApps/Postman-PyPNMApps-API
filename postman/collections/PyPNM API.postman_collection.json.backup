    {
      "name": "PyPNM Operations",
      "item": [
        {
          "name": "List Operations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pypnm/operations/list",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "pypnm",
                "operations",
                "list"
              ]
            },
            "description": "Returns an array of operation metadata including ID, MAC address, group, and status."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array of operations', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Operations have required fields', function() {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.length > 0) {",
                  "        const operation = jsonData[0];",
                  "        pm.expect(operation).to.have.property('operation_id');",
                  "        pm.expect(operation).to.have.property('status');",
                  "        pm.collectionVariables.set('operation_id', operation.operation_id);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Operation Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pypnm/operations/status/:operation_id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "pypnm",
