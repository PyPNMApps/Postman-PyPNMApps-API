                "status",
                ":operation_id"
              ],
              "variable": [
                {
                  "key": "operation_id",
                  "value": "{{operation_id}}",
                  "description": "Unique operation identifier"
                }
              ]
            },
            "description": "Fetch metadata and current execution state for a given operation ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 404', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Operation status has required fields', function() {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('operation');",
                  "        pm.expect(jsonData).to.have.property('status');",
                  "        pm.expect(jsonData.operation.status).to.be.oneOf(['RUNNING', 'COMPLETED', 'FAILED', 'PENDING']);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
