      "item": [
        {
          "name": "Start Multi RxMER",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cable_modem\": {\n    \"mac_address\": \"38:AD:2B:3E:86:54\",\n    \"ip_address\": \"172.19.32.241\",\n    \"snmp\": {\n      \"snmp_v2c\": {\n        \"community\": \"private\"\n      }\n    },\n    \"pnm_parameters\": {\n      \"tftp\": {\n        \"ipv4\": \"192.168.1.100\"\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/advance/multiRxMer/start",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "advance",
                "multiRxMer",
                "start"
              ]
            },
            "description": "Start multi-channel RxMER capture operation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 202', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
                  "});",
                  "",
                  "pm.test('Multi-device operation initiated', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('object');",
                  "    if (jsonData.operation_id) {",
                  "        pm.collectionVariables.set('operation_id', jsonData.operation_id);",
                  "    }",
                  "    if (jsonData.group_id) {",
                  "        pm.collectionVariables.set('group_id', jsonData.group_id);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Multi RxMER Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/advance/multiRxMer/status/:operation_id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "advance",
                "multiRxMer",
                "status",
                ":operation_id"
              ],
              "variable": [
                {
                  "key": "operation_id",
                  "value": "{{operation_id}}",
                  "description": "Operation ID"
                }
              ]
            },
            "description": "Get status of multi-channel RxMER operation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 404', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    pm.test('Operation status has required fields', function() {",
                  "        const jsonData = pm.response.json();",
                  "        pm.expect(jsonData).to.have.property('operation_id');",
                  "        pm.expect(jsonData).to.have.property('status');",
                  "        pm.expect(jsonData.operation.status).to.be.oneOf(['RUNNING', 'COMPLETED', 'FAILED', 'PENDING']);",
                  "    });",
                  "}"
                ]
              }
            }
          ]
        },
        {
