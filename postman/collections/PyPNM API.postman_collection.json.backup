        },
        {
          "name": "Multi RxMer Analysis - Min Avg Max",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"analysis\":{\"type\":\"min-avg-max\",\"output\":{\"type\":\"json\"},\"plot\":{\"ui\":{\"theme\":\"dark\"}}},\"operation_id\":\"4dfa1ba3214e4944\"}"
            },
            "url": {
              "raw": "{{base_url}}/advance/multiRxMer/analysis",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "advance",
                "multiRxMer",
                "analysis"
              ]
            },
            "description": "Perform min-avg-max analysis on multi-channel RxMER data for a completed operation."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Test Assertions",
                  "pm.test(\"Response status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has required fields\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('mac_address');",
                  "    pm.expect(jsonData).to.have.property('status');",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Status field equals 0 (success)\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql(0);",
                  "});",
                  "",
                  "pm.test(\"Data contains channel information with required arrays\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('object');",
                  "    ",
                  "    // Check each channel in data",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        pm.expect(channel).to.have.property('channel_id');",
                  "        pm.expect(channel).to.have.property('frequency');",
                  "        pm.expect(channel).to.have.property('min');",
                  "        pm.expect(channel).to.have.property('avg');",
                  "        pm.expect(channel).to.have.property('max');",
                  "        ",
                  "        pm.expect(channel.frequency).to.be.an('array');",
                  "        pm.expect(channel.min).to.be.an('array');",
                  "        pm.expect(channel.avg).to.be.an('array');",
                  "        pm.expect(channel.max).to.be.an('array');",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"All arrays have the same length\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        const freqLength = channel.frequency.length;",
                  "        ",
                  "        pm.expect(channel.min.length).to.eql(freqLength);",
                  "        pm.expect(channel.avg.length).to.eql(freqLength);",
                  "        pm.expect(channel.max.length).to.eql(freqLength);",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Min values are less than or equal to avg values\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        ",
                  "        for (let i = 0; i < channel.min.length; i++) {",
                  "            pm.expect(channel.min[i]).to.be.at.most(channel.avg[i]);",
                  "        }",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Avg values are less than or equal to max values\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        ",
                  "        for (let i = 0; i < channel.avg.length; i++) {",
                  "            pm.expect(channel.avg[i]).to.be.at.most(channel.max[i]);",
                  "        }",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Frequency values are in ascending order\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        ",
                  "        for (let i = 1; i < channel.frequency.length; i++) {",
                  "            pm.expect(channel.frequency[i]).to.be.above(channel.frequency[i-1]);",
                  "        }",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"All numeric values are within reasonable ranges\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    Object.keys(jsonData.data).forEach(channelKey => {",
                  "        const channel = jsonData.data[channelKey];",
                  "        ",
                  "        channel.min.forEach(val => pm.expect(val).to.be.within(0, 100));",
                  "        channel.avg.forEach(val => pm.expect(val).to.be.within(0, 100));",
                  "        channel.max.forEach(val => pm.expect(val).to.be.within(0, 100));",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
