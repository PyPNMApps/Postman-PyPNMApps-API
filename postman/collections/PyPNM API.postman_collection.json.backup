    {
      "name": "PNM - Downstream OFDM",
      "item": [
        {
          "name": "Get RxMER Capture",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cable_modem\": {\n    \"mac_address\": \"38:AD:2B:3E:86:54\",\n    \"ip_address\": \"172.19.32.241\",\n    \"snmp\": {\n      \"snmp_v2c\": {\n        \"community\": \"private\"\n      }\n    },\n    \"pnm_parameters\": {\n      \"tftp\": {\n        \"ipv4\": \"192.168.1.100\",\n        \"ipv6\": null\n      }\n    }\n  },\n  \"analysis\": {\n    \"output\": {\n      \"type\": \"json\"\n    },\n    \"plot\": {\n      \"ui\": {\n        \"theme\": \"light\"\n      }\n    }\n  }\n}"
            },
